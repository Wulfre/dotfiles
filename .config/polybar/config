[bar/top]
width = 100%
height = 24
padding = 1
font-0 = MonoLisa:size=12;1
font-1 = "Font Awesome 5 Pro Regular:size=12;2"
font-2 = "Font Awesome 5 Pro Solid:size=12;2"
foreground = #D8DEE9
background = #2E3440
module-margin = 1
modules-left = date
modules-center = workspaces
modules-right = pulseaudio sep battery

[module/date]
type = internal/date
format = <label>
date = %A, %d %B %Y
time = %I:%M %p
label = %date%, %time%

[module/workspaces]
type = internal/xworkspaces
pin-workspaces = true
enable-click = true
enable-scroll = true
format-padding = 1

format = <label-state>
label-active = 
label-active-font = 3
label-occupied = 
label-urgent = 
label-empty = 

label-active-padding = 1
label-occupied-padding = 1
lavel-urgent-padding = 1
label-empty-padding = 1

[module/battery]
type = internal/battery
full-at = 99
format-discharging = <ramp-capacity> <label-discharging>
format-full = <ramp-capacity> <label-full>
battery = BAT0
adapter = AC0

ramp-capacity-0 = 
ramp-capacity-1 = 
ramp-capacity-2 = 
ramp-capacity-3 = 
ramp-capacity-4 = 

label-charging =  %percentage%
label-discharging = %percentage%
label-full = %percentage%

[module/pulseaudio]
type = internal/pulseaudio
format-volume = <ramp-volume> <label-volume>
ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 
ramp-volume-3 = 
label-muted =  MUTE
label-volume = %percentage%
